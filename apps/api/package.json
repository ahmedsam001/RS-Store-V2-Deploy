{
  "name": "@rs-store/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "test": "node --test --require ts-node/register test/*.test.ts",
    "db:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:status": "prisma migrate status --schema=prisma/schema.prisma",
    "db:validate": "prisma validate --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.10",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.10",
    "@nestjs/platform-express": "^11.0.10",
    "@prisma/client": "^6.2.1",
    "cloudinary": "^2.5.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "prisma": "^6.2.1",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.12"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
