NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=https://api.rs-store.me/api/v1

DATABASE_URL=postgresql://rs_store:rs_store_password@localhost:5432/rs_store?schema=public
REDIS_URL=redis://localhost:6379
POSTGRES_USER=rs_store
POSTGRES_PASSWORD=rs_store_password
POSTGRES_DB=rs_store
REDIS_PORT=6379

CLOUDINARY_CLOUD_NAME=Root
CLOUDINARY_API_KEY=415175888742347
CLOUDINARY_API_SECRET=OYbAwJfrLnRiCF44KF2HbTIYvbc

SESSION_COOKIE_NAME=rs_session
CSRF_COOKIE_NAME=rs_csrf
GUEST_COOKIE_NAME=rs_guest
GUEST_COOKIE_SECRET=development_guest_cookie_secret_change_me_32_chars
GUEST_TTL_SECONDS=2592000
SESSION_TTL_SECONDS=28800
REMEMBER_ME_TTL_SECONDS=2592000
COOKIE_SECURE=false

UPLOAD_MAX_IMAGE_BYTES=5242880
UPLOAD_ALLOWED_FOLDERS=rs-store/products,rs-store/categories,rs-store/settings,rs-store/order-proofs,rs-store/shein-imports

ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_NAME=RS Store Owner
ADMIN_BOOTSTRAP_EMAIL=owner@example.com
ADMIN_BOOTSTRAP_PHONE=+201018313022
ADMIN_BOOTSTRAP_PASSWORD=ahmedsami7525@

# SHEIN browser-assisted import behavior
SHEIN_IMPORT_COUNTRY_CODE=SA
SHEIN_IMPORT_CURRENCY=SAR
SHEIN_IMPORT_LANGUAGE=en
# interactive = opens a real visible Chrome window like V1 so the admin can pass CAPTCHA.
# headless = server-side dump only. 0/off = manual fallback only.
SHEIN_BROWSER_IMPORT=off
SHEIN_BROWSER_TIMEOUT_MS=6000
SHEIN_ASSIST_MAX_WAIT_MS=600000
SHEIN_ASSIST_POLL_MS=2000
SHEIN_BROWSER_NO_SANDBOX=true
# Set this only if Chrome is not found automatically.
# Optional local development only: enable visible Chrome when the API runs outside Docker with DISPLAY available.
# SHEIN_BROWSER_IMPORT=interactive
# SHEIN_BROWSER_PATH=/usr/bin/google-chrome
# Docker Linux GUI mode uses docker-compose.shein-gui.yml and /usr/bin/chromium-browser.
# Keep 0 for the real visible V1-style window. Use 1 only for server/headless diagnostics.
SHEIN_ASSIST_HEADLESS=0
# Optional: if you import SHEIN in SAR and show customer prices in EGP
# SHEIN_CUSTOMER_CURRENCY=EGP
# SHEIN_SAR_TO_EGP_RATE=13
# Frontend-only values used by the Admin SHEIN Open link button.
# Keep these equal to SHEIN_IMPORT_* above when testing locally.
VITE_SHEIN_IMPORT_COUNTRY_CODE=SA
VITE_SHEIN_IMPORT_CURRENCY=SAR
VITE_SHEIN_IMPORT_LANGUAGE=en
